# ==============================
# 환경변수 및 민감정보
# ==============================
.env
.env.*
!.env.example


# ==============================
# Python 가상환경
# ==============================
.venv/
venv/
env/
ENV/


# ==============================
# Python 캐시 및 컴파일 파일
# ==============================
__pycache__/
*.py[cod]
*$py.class


# ==============================
# 테스트 및 정적 분석 캐시
# ==============================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/


# ==============================
# 패키징 및 빌드 결과물
# ==============================
build/
dist/
*.egg-info/
.eggs/


# ==============================
# SQLite 데이터베이스
# 최종 DB 파일은 Git이 아니라 별도로 제출
# ==============================
*.db
*.sqlite
*.sqlite3
*.db-journal


# ==============================
# 로그 및 임시 파일
# ==============================
*.log
logs/
tmp/
temp/
*.tmp


# ==============================
# IDE 설정
# ==============================
.vscode/
.idea/
*.iml


# ==============================
# 운영체제 자동 생성 파일
# ==============================
.DS_Store
Thumbs.db
desktop.ini


# ==============================
# Python 버전 및 로컬 설정
# ==============================
.python-version
.python-version.*